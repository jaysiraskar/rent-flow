# SQL Server
MSSQL_SA_PASSWORD=Your_strong_password_123!

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
JWT_KEY=replace-with-a-very-long-random-secret-at-least-32-chars
JWT_ISSUER=RentFlow
JWT_AUDIENCE=RentFlow.Client

# SMTP (optional for reminders)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@rentflow.in
SMTP_FROM_NAME=RentFlow
SMTP_ENABLE_SSL=true

# Reminder scheduler
REMINDER_UPCOMING_DAYS=3
REMINDER_INTERVAL_MINUTES=60
